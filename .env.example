# Pexels API for image fetching
PEXELS_API_KEY=your_pexels_api_key_here

# TTS Engine Selection
# Options: "pyttsx3" (default, free, local), "gtts" (free, Google), "elevenlabs" (premium, best quality)
TTS_ENGINE=pyttsx3

# TTS Configuration
TTS_VOICE_NAME=default          # For pyttsx3: voice name (e.g., "Victoria", "David")
TTS_VOICE_ID=                   # For ElevenLabs: voice ID
TTS_RATE=150                    # Speech rate (75-300, default 150)
TTS_VOLUME=1.0                  # Volume (0.0-1.0)
TTS_LANGUAGE=en                 # Language code (en, es, fr, etc.)

# ElevenLabs API Key (only needed if TTS_ENGINE=elevenlabs)
# Get free credits at: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
